{
  "api_version": "1.0",
  "base_url": "http://localhost:8080/api/v1",
  "endpoints": {
    "auth": [
      {
        "method": "POST",
        "path": "/auth/login",
        "description": "Authenticate user and get JWT token",
        "request_body": {
          "email": "string",
          "password": "password123"
        },
        "response": {
          "token": "jwt_token_string",
          "type": "Bearer",
          "email": "user@example.com",
          "role": "ROLE_PASSENGER"
        }
      },
      {
        "method": "POST",
        "path": "/auth/register",
        "description": "Register a new user",
        "request_body": {
          "firstName": "John",
          "lastName": "Doe",
          "email": "john@example.com",
          "password": "password123",
          "phoneNumber": "+1234567890",
          "role": "PASSENGER"
        },
        "response": {
          "token": "jwt_token_string",
          "type": "Bearer",
          "email": "john@example.com",
          "role": "ROLE_PASSENGER"
        }
      }
    ],
    "fleet": [
      {
        "method": "GET",
        "path": "/aircrafts",
        "description": "Get all aircrafts (Operations/Admin only)",
        "response": [
          {
            "id": "uuid",
            "tailNumber": "N12345",
            "model": "Gulfstream G650",
            "passengerCapacity": 14,
            "rangeNauticalMiles": 7000,
            "hourlyRate": 8500.00,
            "currentLocationIata": "JFK",
            "status": "AVAILABLE"
          }
        ]
      },
      {
        "method": "POST",
        "path": "/aircrafts",
        "description": "Add a new aircraft",
        "request_body": {
          "tailNumber": "N12345",
          "model": "Gulfstream G650",
          "passengerCapacity": 14,
          "rangeNauticalMiles": 7000,
          "hourlyRate": 8500.00,
          "currentLocationIata": "JFK"
        }
      },
      {
        "method": "PATCH",
        "path": "/aircrafts/{id}/status?status=MAINTENANCE",
        "description": "Update aircraft status"
      }
    ],
    "flights": [
      {
        "method": "GET",
        "path": "/flights",
        "description": "Get all flights",
        "response": [
          {
            "id": "uuid",
            "aircraft": { "id": "uuid", "tailNumber": "N12345" },
            "departureAirportIata": "LAX",
            "arrivalAirportIata": "JFK",
            "scheduledDeparture": "2026-06-22T10:00:00",
            "scheduledArrival": "2026-06-22T15:00:00",
            "flightType": "CHARTER",
            "status": "SCHEDULED"
          }
        ]
      },
      {
        "method": "POST",
        "path": "/flights",
        "description": "Schedule a new flight",
        "request_body": {
          "aircraftId": "uuid",
          "departureAirportIata": "LAX",
          "arrivalAirportIata": "JFK",
          "scheduledDeparture": "2026-06-22T10:00:00",
          "scheduledArrival": "2026-06-22T15:00:00",
          "flightType": "CHARTER"
        }
      },
      {
        "method": "PATCH",
        "path": "/flights/{id}/status?status=EN_ROUTE",
        "description": "Update flight status"
      }
    ],
    "bookings": [
      {
        "method": "POST",
        "path": "/bookings",
        "description": "Create a new charter booking (Passenger only)",
        "request_body": {
          "flightId": "uuid",
          "specialRequests": "Vegetarian catering",
          "totalAmount": 25000.00
        },
        "response": {
          "id": "uuid",
          "bookingReference": "A8X2B91Z",
          "status": "PENDING_PAYMENT"
        }
      },
      {
        "method": "GET",
        "path": "/bookings/me",
        "description": "Get bookings for the logged-in passenger"
      },
      {
        "method": "GET",
        "path": "/bookings",
        "description": "Get all bookings (Agent/Operations only)"
      },
      {
        "method": "PATCH",
        "path": "/bookings/{reference}/status?status=CONFIRMED",
        "description": "Update booking status"
      }
    ]
  }
}
